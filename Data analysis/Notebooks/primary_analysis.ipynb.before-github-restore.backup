                      "metadata":  {

                                   },
                      "outputs":  [

                                  ],
                      "source":  [
                                     "print(mental_health.groupby(\"usage_group\")[\"depression_label\"].agg([\"count\", \"sum\", \"mean\"]))\n",
                                     "print(mental_health.groupby(\"usage_group\")[[\"anxiety_level\", \"stress_level\"]].mean())\n",
                                     "print(mental_health.groupby(\"usage_group\")[[\"anxiety_level\", \"stress_level\"]].median())\n"
                                 ]
                  },
