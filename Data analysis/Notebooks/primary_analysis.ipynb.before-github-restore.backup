                                     "    \"sleep_hours\",\n",
                                     "    \"stress_level\",\n",
                                     "    \"anxiety_level\",\n",
                                     "    \"academic_performance\",\n",
                                     "    \"physical_activity\",\n",
                                     "]\n",
                                     "\n",
                                     "mental_health[numeric_cols].describe()\n"
                                 ]
                  },
